{
    "name": "dbu/snake-bundle",
    "type": "bundle",
    "license": "MIT",
    "description": "Snake Game (demo for the Symfony console)",
    "authors": [
        {
            "name": "InfoK1c",
            "email": "quentin.cornet.infok1c@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "symfony/console": "^7.0|^8.0"
    },
    "require-dev": {
        "symfony/framework-bundle": "^7.0|^8.0",
        "symfony/flex": "^2.0",
        "symfony/yaml": "^7.0|^8.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Dbu\\SnakeBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dbu\\Tests\\SnakeBundle\\Fixtures\\": "tests/fixtures/app/src/",
            "Dbu\\Tests\\SnakeBundle\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "tests/fixtures/app/bin/console cache:clear": "script"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    }
}
